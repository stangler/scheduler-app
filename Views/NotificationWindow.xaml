<Window x:Class="SchedulerApp.Views.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="リマインダー" Height="150" Width="350"
        WindowStartupLocation="Manual"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="White" CornerRadius="10" BorderBrush="#4A90D9" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="15" ShadowDepth="3"/>
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <TextBlock Text="🔔" FontSize="18" VerticalAlignment="Center"/>
                <TextBlock Text="リマインダー" FontSize="14" FontWeight="Bold" 
                           Foreground="#4A90D9" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Row="1" x:Name="TitleText" FontSize="16" FontWeight="Bold" 
                       Foreground="#333" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>

            <TextBlock Grid.Row="2" x:Name="TimeText" FontSize="12" 
                       Foreground="#666" Margin="0,4,0,0"/>

            <Button Grid.Row="3" Content="閉じる" HorizontalAlignment="Right"
                    Padding="16,6" Background="#4A90D9" Foreground="White"
                    BorderThickness="0" Click="Close_Click" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>
