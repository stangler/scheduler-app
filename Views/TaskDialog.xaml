<Window x:Class="SchedulerApp.Views.TaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="タスクの編集" Height="560" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border Margin="0" Background="#F5F7FA">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#4A90D9">
                <TextBlock x:Name="DialogTitle" Text="タスクを追加" FontSize="18" 
                           FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center" Margin="20,0"/>
            </Border>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,8,20,8">

                    <TextBlock Text="タイトル *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TitleBox" MaxLength="100"/>

                    <TextBlock Text="説明" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="DescriptionBox" Height="70" 
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="カラー" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="ColorCombo" SelectionChanged="ColorCombo_SelectionChanged">
                        <ComboBoxItem Tag="#4A90D9" Content="🔵 ブルー" IsSelected="True"/>
                        <ComboBoxItem Tag="#E74C3C" Content="🔴 レッド"/>
                        <ComboBoxItem Tag="#2ECC71" Content="🟢 グリーン"/>
                        <ComboBoxItem Tag="#F39C12" Content="🟡 オレンジ"/>
                        <ComboBoxItem Tag="#9B59B6" Content="🟣 パープル"/>
                        <ComboBoxItem Tag="#1ABC9C" Content="🟦 ティール"/>
                    </ComboBox>

                    <TextBlock Text="開始日時 *" Style="{StaticResource LabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <DatePicker x:Name="StartDatePicker" Grid.Column="0" BorderBrush="#DDD" Background="White" FontSize="13"/>
                        <TextBox x:Name="StartTimeBox" Grid.Column="2" Text="09:00" TextAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="終了日時（任意）" Style="{StaticResource LabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <DatePicker x:Name="EndDatePicker" Grid.Column="0" BorderBrush="#DDD" Background="White" FontSize="13"/>
                        <TextBox x:Name="EndTimeBox" Grid.Column="2" Text="" TextAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="繰り返し" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="RecurrenceCombo">
                        <ComboBoxItem Content="なし" Tag="None" IsSelected="True"/>
                        <ComboBoxItem Content="毎日" Tag="Daily"/>
                        <ComboBoxItem Content="毎週" Tag="Weekly"/>
                        <ComboBoxItem Content="毎月" Tag="Monthly"/>
                        <ComboBoxItem Content="毎年" Tag="Yearly"/>
                    </ComboBox>

                    <!-- Reminder -->
                    <TextBlock Text="リマインダー" Style="{StaticResource LabelStyle}"/>
                    <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="12,10">
                        <StackPanel>
                            <CheckBox x:Name="ReminderCheck" Content="リマインダーを有効にする" 
                                      FontSize="13" Checked="ReminderCheck_Changed" Unchecked="ReminderCheck_Changed"/>
                            <Grid x:Name="ReminderPanel" Visibility="Collapsed" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="ReminderCombo" Grid.Column="0">
                                    <ComboBoxItem Content="5分前" Tag="5" IsSelected="True"/>
                                    <ComboBoxItem Content="10分前" Tag="10"/>
                                    <ComboBoxItem Content="15分前" Tag="15"/>
                                    <ComboBoxItem Content="30分前" Tag="30"/>
                                    <ComboBoxItem Content="1時間前" Tag="60"/>
                                    <ComboBoxItem Content="2時間前" Tag="120"/>
                                    <ComboBoxItem Content="1日前" Tag="1440"/>
                                </ComboBox>
                                <TextBlock Grid.Column="1" Text="に通知" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#666"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="White" BorderBrush="#EEE" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12">
                    <Button Content="キャンセル" Width="100" Height="36" Margin="0,0,8,0"
                            Background="White" BorderBrush="#DDD" BorderThickness="1"
                            Click="Cancel_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6" Padding="12,8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="SaveButton" Content="保存" Width="100" Height="36"
                            Background="#4A90D9" Foreground="White" BorderThickness="0"
                            Click="Save_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="6" Padding="12,8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
