<Window x:Class="SchedulerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SchedulerApp"
        Title="📅 スケジューラー" Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">
    <Window.Resources>
        <!-- Day Cell Style -->
        <Style x:Key="DayCellStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Margin="2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EBF5FB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Task Item Style -->
        <Style x:Key="TaskItemStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="#2C3E50">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📅" FontSize="22" VerticalAlignment="Center"/>
                    <TextBlock Text="スケジューラー" FontSize="20" FontWeight="Bold" 
                               Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <!-- Today indicator -->
                <TextBlock Grid.Column="1" x:Name="TodayLabel" 
                           FontSize="13" Foreground="#AAA" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <!-- Add Task button -->
                <Button Grid.Column="2" Content="＋ タスクを追加" 
                        Background="#4A90D9" Foreground="White"
                        Padding="16,8" Click="AddTask_Click"
                        Style="{StaticResource ActionButtonStyle}" FontSize="13"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Calendar Panel -->
            <Border Grid.Column="0" Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.08" BlurRadius="12" ShadowDepth="2"/>
                </Border.Effect>
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Month Navigation -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="◀" Width="32" Height="32"
                                Background="#F0F2F5" Foreground="#333" BorderThickness="0"
                                Click="PrevMonth_Click" Style="{StaticResource ActionButtonStyle}"
                                FontSize="14"/>

                        <TextBlock Grid.Column="1" x:Name="MonthLabel" 
                                   FontSize="17" FontWeight="Bold" Foreground="#2C3E50"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>

                        <Button Grid.Column="2" Content="今日" Width="48" Height="32"
                                Background="#EBF5FB" Foreground="#4A90D9" BorderThickness="0"
                                Click="Today_Click" Style="{StaticResource ActionButtonStyle}"
                                FontSize="12" Margin="0,0,4,0"/>

                        <Button Grid.Column="3" Content="▶" Width="32" Height="32"
                                Background="#F0F2F5" Foreground="#333" BorderThickness="0"
                                Click="NextMonth_Click" Style="{StaticResource ActionButtonStyle}"
                                FontSize="14"/>
                    </Grid>

                    <!-- Weekday Headers -->
                    <UniformGrid Grid.Row="1" Rows="1" Columns="7" Margin="0,0,0,4">
                        <TextBlock Text="日" TextAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#E74C3C" Padding="0,4"/>
                        <TextBlock Text="月" TextAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#666" Padding="0,4"/>
                        <TextBlock Text="火" TextAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#666" Padding="0,4"/>
                        <TextBlock Text="水" TextAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#666" Padding="0,4"/>
                        <TextBlock Text="木" TextAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#666" Padding="0,4"/>
                        <TextBlock Text="金" TextAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#666" Padding="0,4"/>
                        <TextBlock Text="土" TextAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#4A90D9" Padding="0,4"/>
                    </UniformGrid>

                    <!-- Calendar Grid -->
                    <UniformGrid Grid.Row="2" x:Name="CalendarGrid" Rows="6" Columns="7"/>
                </Grid>
            </Border>

            <!-- RIGHT: Task List Panel -->
            <Border Grid.Column="2" Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.08" BlurRadius="12" ShadowDepth="2"/>
                </Border.Effect>
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Task panel header -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SelectedDateLabel" FontSize="16" FontWeight="Bold" 
                                   Foreground="#2C3E50" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="TaskCountLabel" 
                                   FontSize="12" Foreground="#999" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Filter tabs -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,12">
                        <Button x:Name="FilterAllBtn" Content="すべて" Padding="12,6"
                                Background="#4A90D9" Foreground="White"
                                Style="{StaticResource ActionButtonStyle}" FontSize="12"
                                Click="FilterAll_Click" Margin="0,0,4,0"/>
                        <Button x:Name="FilterTodayBtn" Content="今日" Padding="12,6"
                                Background="#F0F2F5" Foreground="#666"
                                Style="{StaticResource ActionButtonStyle}" FontSize="12"
                                Click="FilterToday_Click" Margin="0,0,4,0"/>
                        <Button x:Name="FilterUpcomingBtn" Content="今後" Padding="12,6"
                                Background="#F0F2F5" Foreground="#666"
                                Style="{StaticResource ActionButtonStyle}" FontSize="12"
                                Click="FilterUpcoming_Click"/>
                    </StackPanel>

                    <!-- Task List -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="TaskListPanel">
                            <!-- Tasks added dynamically -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
